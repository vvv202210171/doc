{
  "info": {
    "_postman_id": "api-complete-collection",
    "name": "完整 API 集合（包含图片管理）",
    "description": "包含 C2C 商户、收款方式和图片管理的完整 API Collection",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "📸 资源管理接口",
      "item": [
        {
          "name": "图片上传",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "imgurl",
                  "type": "file",
                  "src": ""
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/res/upload",
              "host": ["{{baseUrl}}"],
              "path": ["res", "upload"]
            },
            "description": "上传图片文件\n\n**支持的图片格式：**\n- jpg, jpeg, png, gif, bmp, svg, tiff, dxf, pcx, ufo, tga, raw, ai, fpx, eps\n\n**返回值说明：**\n- resseq: 资源序列号，用于后续预览\n\n**完整预览 URL：**\n`{{baseUrl}}/res/preview/{resseq}`"
          }
        },
        {
          "name": "图片预览",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/res/preview/{{resseq}}",
              "host": ["{{baseUrl}}"],
              "path": ["res", "preview", "{{resseq}}"]
            },
            "description": "预览图片文件\n\n**参数说明：**\n- resseq: 资源序列号（来自图片上传接口返回值）\n\n**缓存策略：**\n- 图片会在浏览器缓存 7 天\n- 首次加载后重复访问不需重新下载\n\n**使用场景：**\n- 在 HTML img 标签中使用该 URL\n- 在创建收款方式时使用该 URL 作为 wxUrl/alipayUrl"
          }
        }
      ]
    },
    {
      "name": "🏪 C2C 商户管理",
      "item": [
        {
          "name": "创建商户",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"我的商户\",\n  \"phone\": \"13800138000\",\n  \"type\": \"PERSONAL\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/c2c/merchant/create",
              "host": ["{{baseUrl}}"],
              "path": ["c2c", "merchant", "create"]
            },
            "description": "创建 C2C 商户\n\n**必填参数：**\n- name: 商户名称（不能重复）\n- phone: 联系电话\n\n**可选参数：**\n- type: PERSONAL（个人）/ PLATFORM（平台），默认 PERSONAL"
          }
        },
        {
          "name": "重新提交商户信息",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"我的商户-修改版\",\n  \"phone\": \"13900139000\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/c2c/merchant/recommit",
              "host": ["{{baseUrl}}"],
              "path": ["c2c", "merchant", "recommit"]
            },
            "description": "商户被拒绝后重新提交信息"
          }
        },
        {
          "name": "获取商户详情",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/c2c/merchant/detail",
              "host": ["{{baseUrl}}"],
              "path": ["c2c", "merchant", "detail"]
            },
            "description": "获取当前登录用户的商户信息"
          }
        },
        {
          "name": "根据商户编码查询",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/c2c/merchant/code/MCH20260302001",
              "host": ["{{baseUrl}}"],
              "path": ["c2c", "merchant", "code", "MCH20260302001"]
            },
            "description": "查询其他商户信息"
          }
        },
        {
          "name": "获取保证金信息",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/c2c/merchant/margin",
              "host": ["{{baseUrl}}"],
              "path": ["c2c", "merchant", "margin"]
            },
            "description": "获取可用的保证金金额列表"
          }
        },
        {
          "name": "更新保证金（激活商户）",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/c2c/merchant/update-margin",
              "host": ["{{baseUrl}}"],
              "path": ["c2c", "merchant", "update-margin"]
            },
            "description": "提交保证金，激活商户状态"
          }
        }
      ]
    },
    {
      "name": "💳 C2C 收款方式",
      "item": [
        {
          "name": "创建收款方式 - 微信",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"collWay\": \"wx\",\n  \"wxUrl\": \"https://www.biyiex.top/api/res/preview/RES202603020001\",\n  \"wxAcc\": \"wechat_account_123\",\n  \"wxName\": \"张三\",\n  \"tag\": \"主账户\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/c2c/collway/create",
              "host": ["{{baseUrl}}"],
              "path": ["c2c", "collway", "create"]
            },
            "description": "创建微信收款方式\n\n**必填参数：**\n- collWay: \"wx\"\n- wxUrl: 微信收款码 URL（来自 /res/preview/{resseq}）\n- wxAcc: 微信账户\n- wxName: 微信账户真实姓名\n\n**可选参数：**\n- tag: 标记/备注"
          }
        },
        {
          "name": "创建收款方式 - 支付宝",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"collWay\": \"alipay\",\n  \"alipayUrl\": \"https://www.biyiex.top/api/res/preview/RES202603020002\",\n  \"alipayAcc\": \"13800138000\",\n  \"alipayName\": \"张三\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/c2c/collway/create",
              "host": ["{{baseUrl}}"],
              "path": ["c2c", "collway", "create"]
            },
            "description": "创建支付宝收款方式"
          }
        },
        {
          "name": "创建收款方式 - 银行卡",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"collWay\": \"bank\",\n  \"bankName\": \"中国工商银行\",\n  \"bankAcc\": \"6222022409001234567\",\n  \"bankHolder\": \"张三\",\n  \"bankAddr\": \"北京市朝阳区支行\",\n  \"tag\": \"工行账户\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/c2c/collway/create",
              "host": ["{{baseUrl}}"],
              "path": ["c2c", "collway", "create"]
            },
            "description": "创建银行卡收款方式"
          }
        },
        {
          "name": "解绑收款方式",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/c2c/collway/unbind?id=1",
              "host": ["{{baseUrl}}"],
              "path": ["c2c", "collway", "unbind"],
              "query": [
                {
                  "key": "id",
                  "value": "1"
                }
              ]
            },
            "description": "删除/解绑收款方式"
          }
        },
        {
          "name": "获取所有收款方式",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/c2c/collway/all",
              "host": ["{{baseUrl}}"],
              "path": ["c2c", "collway", "all"]
            },
            "description": "获取所有收款方式列表"
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "https://www.biyiex.top/api",
      "type": "string"
    },
    {
      "key": "token",
      "value": "your_bearer_token_here",
      "type": "string"
    },
    {
      "key": "resseq",
      "value": "RES202603020001",
      "type": "string"
    }
  ]
}

